[node name="Label" type="Label" parent="Container/ControllerDisplay/Build/BuildPages/Build3/VBoxContainer" unique_id=1630808450]
custom_minimum_size = Vector2(750, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "Now that you can summon your objects, you may want to combine some them, you can combine objects after placing them down already but you can also combine them upon summoning them.
To do so, while holding down the A button to get a preview, hover your \"pointer\" over another existing object, it should snap to the object when the \"pointer\" appears upon release the objects will be combined!"
horizontal_alignment = 1
autowrap_mode = 3

