layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "Now that you have placed down some vertices, you can connect them together,
To do this you must first point with the right controller to highlight it, afterwards you can press the grip, you'll notice its color change
You can now while keeping that grip hover over another vertex, you'll see a preview edge appear, upon release it'll connect those two vertices together and draw a line!
Connect all your 4 vertices together!"
horizontal_alignment = 1
autowrap_mode = 3

