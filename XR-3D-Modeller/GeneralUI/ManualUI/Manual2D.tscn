[node name="Label" type="Label" parent="Container/ControllerDisplay/Export/ExportPages/Export2/VBoxContainer" unique_id=1805842982]
custom_minimum_size = Vector2(750, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "Now that you probably have some sort of completed object either with the vertice creation or the CSG operation, you can render that object / structure!
Keep in mind rendered objects aren't saved in the scene through file saving, they are just for playing around with, don't worry you can still export it and have it saved!
To render an object, select your structure and hit render, in this mode you are always on Group select, the object would have spawned in front of you, play around with it!"
horizontal_alignment = 1
autowrap_mode = 3

