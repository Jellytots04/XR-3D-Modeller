[node name="Label" type="Label" parent="Container/ControllerDisplay/Export/ExportPages/Export3/VBoxContainer" unique_id=655720492]
custom_minimum_size = Vector2(750, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "That rendered object you just created can now be exported as a Godot .tscn file to be used in other projects, to do so select the rendered object, once selected you can then hit the Godot Export button, a line bar should appear and then you can type a name for your file, once you are happy with its name hit Godot Export again and wait for the ping to tell you if it was successful or not!
To see how to pull this save file from the headset to a computer check the FAQ"
horizontal_alignment = 1
