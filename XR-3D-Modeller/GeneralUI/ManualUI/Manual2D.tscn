[node name="Label" type="Label" parent="Container/ControllerDisplay/Export/ExportPages/Export4/VBoxContainer" unique_id=538531428]
custom_minimum_size = Vector2(750, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "Maybe you want a more professional software, more professional than this one, it hurts to hear that.
But you can still do that, the same way you dont the Godot Exprort.
Select your rendered object, once selected hit the .OBJ Export button, give your file a name, and hit .OBJ Export button once more, wait for the ping and BOOM, its saved!
If you want to pull the ,OBJ file to be used elsewhere check the FAQ"
horizontal_alignment = 1
