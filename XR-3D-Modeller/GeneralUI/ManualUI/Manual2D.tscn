custom_minimum_size = Vector2(750, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "This tab is where magic appears, here you are able to spawn in 3D shapes, vertices and copy existing structures in the world, click onto the build tab to start.
The objects you spawn into this environment are CSG shapes and follow the 3 operations of Union, Intersection and Subtraction.
Click on ahead to understand how to start building!
Feel free to build along while reading!"
