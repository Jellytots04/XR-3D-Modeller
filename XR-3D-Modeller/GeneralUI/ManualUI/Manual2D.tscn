[node name="Label" type="Label" parent="Container/ControllerDisplay/Build/BuildPages/Build9/VBoxContainer" unique_id=1956144319]
custom_minimum_size = Vector2(750, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "Now once you have at least 4 vertices summoned, and each vertex has at least 3 connections, assuming the object has created 4 planes, you can now load the shape.
Click the Load button on the UI Controller and the object will be validated.
If it is okay you will get a positive message, if its not okay you'll be told what you are missing!
Keep in mind this follows Euler's Manifold Formula Vertices - Edges + Faces = 2"
horizontal_alignment = 1
autowrap_mode = 3

