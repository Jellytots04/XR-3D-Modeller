[node name="Label" type="Label" parent="Container/ControllerDisplay/FAQ/FAQPages/FAQ3/VBoxContainer" unique_id=1907502186]
custom_minimum_size = Vector2(750, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "Open up your command Prompt
for the Godot Scenes type in
adb pull /sdcard/Android/data/com.jello.polymesh/files/meshes/
to specify do /meshes/file_name.tscn
adb pull /sdcard/Android/data/com.jello.polymesh/files/objects/
to specifiy do /objects/file_name.obj and /objects/file_name.mtl"
