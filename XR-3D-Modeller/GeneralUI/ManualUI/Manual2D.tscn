layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "how to set up to pull files?"
horizontal_alignment = 1

[node name="Label" type="Label" parent="Container/ControllerDisplay/FAQ/FAQPages/FAQ2/VBoxContainer" unique_id=1489484438]
custom_minimum_size = Vector2(750, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "To pull your files, firstly you need to have some sort of connection established with your headset to your PC or Laptop.
Ensure you have ADB (Android Debug Bridge) installed on your device and added to your environment path.
Once your device is connected and ADB is installed you are ready to pull the files."
horizontal_alignment = 1
autowrap_mode = 3

[node name="FAQ3" type="Panel" parent="Container/ControllerDisplay/FAQ/FAQPages" unique_id=1732646631]
