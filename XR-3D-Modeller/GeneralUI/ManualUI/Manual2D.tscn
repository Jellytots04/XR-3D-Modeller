[node name="Label" type="Label" parent="Container/ControllerDisplay/Introduction/IntroPages/Intro6/VBoxContainer" unique_id=4056121]
custom_minimum_size = Vector2(480, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "This is how you interact with basically everything in this software, similar to pointing and click with a mouse, except this time you are physically pointing at it with your \"hand\", \"finger\", \"thumb\", \"controller\" whatever you want to call it.
Whenever you do point at something you may see this little beam appear, that is telling you where exactly you're pointing to!"
horizontal_alignment = 1
autowrap_mode = 3

