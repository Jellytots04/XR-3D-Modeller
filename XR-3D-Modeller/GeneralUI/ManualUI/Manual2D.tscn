custom_minimum_size = Vector2(750, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "Now maybe you are on the run and are already on a save file or have saved recently, don't worry you can always just hit quick save and it'll save to your current file.
On your HUD check to make sure that you are on the file you want to save to and hit quick save it will save the scene to that file!
 If you aren't on a scene then it will just automatically do the Save As operation."
horizontal_alignment = 1
