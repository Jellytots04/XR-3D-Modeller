[node name="Label" type="Label" parent="Container/ControllerDisplay/Introduction/IntroPages/Intro3/TextBoxExample" unique_id=2106347217]
custom_minimum_size = Vector2(750, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "You may want to move and be free, to do so you can use the left controller joystick to walk around the virtual environment and in the passthrough environment.
Do note in passthrough you won't actually be moving your body you have legs for that, but the scene will be moving for you!
As for looking around, you can turn your head or use your right controller joystick to turn the camera!"
horizontal_alignment = 1
autowrap_mode = 3

