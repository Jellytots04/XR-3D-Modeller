layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "You can always return to this manual if you can't remember how to do something.
If you want to just get around quickly, feel free to use the Tab >> or << Tab buttons to skip tabs or just click onto the tab you'd like to visit.

That is all I have for this introduciton enjoy learning and creating!"
horizontal_alignment = 1
