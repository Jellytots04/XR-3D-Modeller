custom_minimum_size = Vector2(750, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "In this tab you are able to save, quick save and load any up any scenes.
Let's say you need to stop working on a scene then feel free to hit Save as and always come back to it later!.
Maybe just for a quick break!
You can always expect it to be back here ready to load!"
