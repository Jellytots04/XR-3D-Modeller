custom_minimum_size = Vector2(600, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "If you want to summon an object you can click on one of these 3 buttons to select that respecitve object.
Tosummon it you may press the A button on your right controller. 
You will firstly notice a ghosted object appear, that is just a preview, upon releasing the A button the object will appear infront of you. Congrats you have just summoned your first shape"
