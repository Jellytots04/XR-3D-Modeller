layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "Now that you have your scene saved and want to return to it, to do so you have to find the files name in your list under the load title, there your files will appear!
When you want to load a certain file, just click it with trigger and once its highlighted press load, and wait for the load transition!
Keep in mind it will clear everything in your current scene so don't forget to save before loading a new scene!"
