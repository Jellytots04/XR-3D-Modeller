layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "Whichever path you ran the commands from thats the location you will see the folders and or singluar files
For example
Windows: C:\\Users\\YourName\\ ,by default this is where cmd opens on.
Mac: YourName@MacBook-Pro ~ % , Terminal opens here.
Linux: YourName@hostname:~$ , Terminal opens here."
