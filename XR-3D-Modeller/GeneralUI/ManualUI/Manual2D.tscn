[node name="Label" type="Label" parent="Container/ControllerDisplay/File/FilePages/File2/VBoxContainer" unique_id=1499249819]
custom_minimum_size = Vector2(750, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "Now you may wonder how do you actually save the scene, well once you're happy with its state and are ready to quit and move on, hit the Save As button, you should see the keyboard and editable line appear, you can start typing a name you wan't to give your save file!, Keep in mind there is a 60 Character limit!
Once you are happy with your name for the file just hit the confirm button and wait for the confirmation popup, now check the HUD to see your file name saved!"
horizontal_alignment = 1
